**/data/processed/
**/data/*.json
**/data/*.csv
crawl_summary.json
logs/

# NodeJS (Backend & Frontend)
node_modules/
.npm
dist/
.next/
out/
build/
*.local

# IDEs & OS
.vscode/
.idea/
.DS_Store
Thumbs.db
